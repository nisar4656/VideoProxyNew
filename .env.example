# ── Server ────────────────────────────────────────────────────────────────────
# Port to listen on (default: 3000)
PORT=3000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all (default: *)
ALLOWED_ORIGINS=*

# ── Domain whitelist ──────────────────────────────────────────────────────────
# Comma-separated list of upstream domains the proxy is allowed to fetch from.
# Leave empty (default) to allow any domain.
# Example:  ALLOWED_DOMAINS=cdn.example.com,media.example.org
ALLOWED_DOMAINS=

# ── Manifest cache ────────────────────────────────────────────────────────────
# How long (in seconds) to cache m3u8 / MPD manifests (default: 30)
CACHE_TTL=30

# Maximum number of manifest entries to hold in memory (default: 200)
MAX_CACHE_KEYS=200

# ── Network ───────────────────────────────────────────────────────────────────
# Upstream request timeout in milliseconds (default: 30000)
REQUEST_TIMEOUT=30000

# User-Agent sent to upstream servers
USER_AGENT=Mozilla/5.0 (compatible; VideoProxy/1.0)
