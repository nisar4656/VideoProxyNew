{
  "name": "video-proxy",
  "version": "1.0.0",
  "description": "A video proxy server supporting HLS (m3u8), MPEG-DASH, and direct video streams with range request support",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "node scripts/build.js",
    "start": "node dist/index.js",
    "dev": "nodemon src/index.js",
    "build": "node scripts/build.js"
  },
  "keywords": [
    "video",
    "proxy",
    "hls",
    "dash",
    "streaming"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.0",
    "express": "^4.19.2",
    "node-cache": "^5.1.2",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
